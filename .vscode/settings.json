    "activityBar.border": "#E9ECEF",
    "activityBarBadge.background": "#5E72E4",
    "activityBarBadge.foreground": "#FFFFFF",
    "activityBar.activeBorder": "#5E72E4",
    "activityBar.activeBackground": "#F6F9FC",
    "sideBar.background": "#FFFFFF",
    "sideBar.foreground": "#67748E",
    "sideBar.border": "#E9ECEF",
    "sideBarTitle.foreground": "#344767",
    "sideBarSectionHeader.background": "#F8F9FA",
    "sideBarSectionHeader.foreground": "#344767",
    "sideBarSectionHeader.border": "#E9ECEF",
    "statusBar.background": "#344767",
