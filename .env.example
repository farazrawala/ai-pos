# Copy to .env.local for personal overrides (optional, gitignored).
# Environments:
#   local       → npm run dev:local      (.env.localhost)
#   development → npm run dev            (.env.development)
#   live        → npm run build:live      (.env.live) — API URL baked in at build time

VITE_APP_NAME=AI POS
VITE_APP_ENV=local
# Subdirectory deploy (e.g. https://example.com/pos/) — use /pos/ for live
# VITE_BASE_PATH=/pos/
# Dev API footer (balance sheet, etc.) — set true to show, false to hide
VITE_DEBUG=false
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_MEDIA_ORIGIN=http://localhost:8000
# Currency (product prices, receipts, etc.)
VITE_CURRENCY_CODE=PKR
VITE_CURRENCY_LOCALE=en-PK
