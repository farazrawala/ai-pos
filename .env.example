# Copy to .env.local for personal overrides (optional, gitignored).
# Environments:
#   local       → npm run dev:local      (.env.localhost)
#   development → npm run dev            (.env.development)
#   live        → npm run build:live      (.env.live)

VITE_APP_NAME=AI POS
VITE_APP_ENV=local
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_MEDIA_ORIGIN=http://localhost:8000
